{
  "name": "senko",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "dev",
  "containerUser": "dev",
  "mounts": [
    "source=mise,target=/home/dev/.local/share/mise,type=volume",
    "source=${localWorkspaceFolderBasename}-prek-cache,target=/home/dev/.cache/prek,type=volume",
    "source=${localWorkspaceFolder}/worktrees,target=${containerWorkspaceFolder}/worktrees,type=bind,consistency=delegated",
    "source=${localWorkspaceFolderBasename}-claude-code,target=/home/dev/.claude,type=volume",
    "source=${localEnv:HOME}/.local/share/chezmoi,target=/home/dev/.local/share/chezmoi,type=bind,consistency=cached",
    "source=${localWorkspaceFolderBasename}-rust,target=/home/dev/.cargo,type=volume",
    "source=${localWorkspaceFolderBasename}-rust-up,target=/home/dev/.rustup,type=volume",
    "source=${localWorkspaceFolderBasename}-senko,target=/home/dev/.local/share/senko,type=volume"
  ],
  "containerEnv": {
    "MISE_TRUSTED_CONFIG_PATHS": "/workspaces/senko"
  },
  "features": {},
  "workspaceFolder": "/workspaces/senko",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/senko,type=bind,consistency=delegated",
  "postCreateCommand": "bash ./.devcontainer/post-create.sh",
  "postStartCommand": "bash ./.devcontainer/post-start.sh"
}
